// Corpocrea Platform - Database Schema
// PostgreSQL on Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// Authentication & Users
// ============================

enum UserRole {
  EMPLOYEE
  MANAGER
  CEO
  ARCHITECT
  ENGINEER
  HR
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String   // bcrypt hash
  role             UserRole @default(EMPLOYEE)
  avatar           String?
  position         String   @default("")
  department       String?
  identificationId String?  @map("identification_id") // Cédula for Odoo
  odooEmployeeId   Int?     @map("odoo_employee_id")
  vacationDays     Float    @default(0)
  socialBenefits   Float    @default(0) // VES
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  loans               Loan[]
  vacationRequests     VacationRequest[]
  documentRequests     DocumentRequest[]
  notifications        Notification[]
  socialBenefitsReqs   SocialBenefitsRequest[]
  sentMessages         ChatMessage[]
  assignedTasks        Task[]
  ledProjects          Project[]       @relation("ProjectLeader")
  participatedProjects ProjectMember[]
  completedTrainings   TrainingCompletion[]

  @@map("users")
}

// ============================
// News & Events (CMS)
// ============================

model NewsItem {
  id          String  @id @default(cuid())
  title       String
  description String
  imageUrl    String? @map("image_url")
  videoUrl    String? @map("video_url")
  type        String  @default("IMAGE") // IMAGE | VIDEO
  date        String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("news")
}

model EventItem {
  id          String @id @default(cuid())
  title       String
  date        String
  location    String @default("")
  description String @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("events")
}

// ============================
// Employees (Public Directory)
// ============================

model Employee {
  id              String   @id @default(cuid())
  name            String
  position        String
  department      String
  photo           String?
  skills          String[] // PostgreSQL array
  isMonthEmployee Boolean  @default(false) @map("is_month_employee")
  birthDate       String   @map("birth_date")
  startDate       String   @map("start_date")

  @@map("employees")
}

// ============================
// Documents
// ============================

model DocumentItem {
  id         String @id @default(cuid())
  name       String
  category   String // Brand, Policy, Template, Manual
  size       String @default("0 MB")
  uploadDate String @map("upload_date")
  department String?
  url        String?

  @@map("documents")
}

// ============================
// HR: Loans
// ============================

enum LoanStatus {
  ACTIVE
  PAID
  PENDING
  REJECTED
}

model Loan {
  id               String     @id @default(cuid())
  userId           String     @map("user_id")
  amount           Float
  balance          Float      @default(0)
  status           LoanStatus @default(PENDING)
  requestDate      String     @map("request_date")
  reason           String     @default("")
  paymentTermMonths Int       @default(0) @map("payment_term_months")
  guarantor        String?
  monthlyIncome    Float?     @map("monthly_income")
  createdAt        DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loans")
}

// ============================
// HR: Vacation Requests
// ============================

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model VacationRequest {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  startDate   String        @map("start_date")
  endDate     String        @map("end_date")
  days        Int
  status      RequestStatus @default(PENDING)
  requestDate String        @map("request_date")
  comments    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vacation_requests")
}

// ============================
// HR: Document Requests
// ============================

enum DocRequestStatus {
  PENDING
  READY
  REJECTED
}

model DocumentRequest {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  type              String          // WORK_CERTIFICATE, INCOME_CERTIFICATE, etc.
  status            DocRequestStatus @default(PENDING)
  requestDate       String          @map("request_date")
  additionalDetails String?         @map("additional_details")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("document_requests")
}

// ============================
// HR: Social Benefits Requests
// ============================

model SocialBenefitsRequest {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  amount      Float
  reason      String        @default("")
  bankAccount String        @default("") @map("bank_account")
  status      RequestStatus @default(PENDING)
  requestDate String        @map("request_date")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("social_benefits_requests")
}

// ============================
// Notifications
// ============================

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id      String           @id @default(cuid())
  userId  String           @map("user_id")
  title   String
  message String
  date    String
  read    Boolean          @default(false)
  type    NotificationType @default(INFO)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================
// Chat
// ============================

model ChatChannel {
  id           String        @id @default(cuid())
  name         String
  type         String        @default("GROUP") // GROUP | DIRECT
  participants String[]      // User IDs or "all"
  createdAt    DateTime      @default(now()) @map("created_at")

  messages ChatMessage[]

  @@map("chat_channels")
}

model ChatMessage {
  id         String   @id @default(cuid())
  channelId  String   @map("channel_id")
  senderId   String   @map("sender_id")
  senderName String   @map("sender_name")
  text       String
  timestamp  DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender  User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ============================
// CEO Message
// ============================

model CeoMessage {
  id        String @id @default("singleton")
  text      String @default("")
  imageUrl  String @default("") @map("image_url")
  updatedAt String @default("") @map("updated_at")

  @@map("ceo_message")
}

// ============================
// Projects & Tasks
// ============================

model Project {
  id          String @id @default(cuid())
  name        String
  description String @default("")
  status      String @default("PLANNING") // ACTIVE, PLANNING, COMPLETED
  deadline    String
  leaderId    String @map("leader_id")

  leader   User            @relation("ProjectLeader", fields: [leaderId], references: [id])
  members  ProjectMember[]
  tasks    Task[]

  @@map("projects")
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String @map("project_id")
  userId    String @map("user_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id               String @id @default(cuid())
  projectId        String @map("project_id")
  title            String
  description      String @default("")
  assignedToUserId String @map("assigned_to_user_id")
  status           String @default("TODO") // TODO, IN_PROGRESS, DONE
  progress         Int    @default(0)
  startDate        String @map("start_date")
  dueDate          String @map("due_date")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User    @relation(fields: [assignedToUserId], references: [id])

  @@map("tasks")
}

// ============================
// Calendar
// ============================

model CalendarEvent {
  id           String  @id @default(cuid())
  title        String
  date         String
  type         String  @default("EVENT") // EVENT | HOLIDAY
  isWorkingDay Boolean @default(true) @map("is_working_day")
  description  String?

  @@map("calendar_events")
}

// ============================
// Trainings
// ============================

model TrainingModule {
  id          String  @id @default(cuid())
  title       String
  description String  @default("")
  department  String  @default("")
  duration    String  @default("")

  completions TrainingCompletion[]

  @@map("training_modules")
}

model TrainingCompletion {
  id         String @id @default(cuid())
  trainingId String @map("training_id")
  userId     String @map("user_id")

  training TrainingModule @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
  @@map("training_completions")
}

// ============================
// Departments
// ============================

model Department {
  id          String  @id @default(cuid())
  name        String
  description String  @default("")
  managerId   String? @map("manager_id")

  @@map("departments")
}

// ============================
// Corporate Companies (Group logos for landing carousel)
// ============================

model CorporateCompany {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String   @map("logo_url")
  website   String?  @default("")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("corporate_companies")
}

// ============================
// Platform Settings (Odoo config, etc.)
// ============================

model Setting {
  key   String @id
  value String @default("")

  @@map("settings")
}
